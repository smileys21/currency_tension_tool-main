# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# Secrets — never commit API keys
.env.local
secrets.toml
.streamlit/secrets.toml

# Raw data cache — large, rebuilt daily by the Action; NOT committed
# EXCEPTION: yields.parquet IS committed (tracked) as a baseline, because RBNZ blocks
# GitHub's servers, so NZ yields can't be fetched from the Action. The committed baseline
# keeps NZD present; the daily backfill merges onto it (fresh data when a source responds,
# last-known-good when it doesn't).
data/cache/macro_backbone.parquet
data/cache/fx_spot.parquet
data/cache/reer.parquet
data/cache/tff.parquet
data/cache/*.sqlite
data/*.db

# Committed snapshot (small; served by the deployed app) is intentionally tracked:
#   tension_map, pillar_scores, overlays, carry_grid_real, carry_grid_nominal,
#   warnings.json, commentary.md, commentary_meta.json

# OS / editor
.DS_Store
.idea/
.vscode/
